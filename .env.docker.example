# Variáveis usadas pelo docker-compose.yml
# Rode com: docker compose --env-file .env.docker up --build

# Postgres
POSTGRES_USER=questions
POSTGRES_PASSWORD=questions
POSTGRES_DB=questions

# API
JWT_SECRET=change-me-in-production

# Web (URL que o browser usa pra chamar a API — baked no bundle do Next)
NEXT_PUBLIC_API_URL=http://localhost:3333

# pgAdmin
PGADMIN_EMAIL=admin@questions.dev
PGADMIN_PASSWORD=admin
